{
  "name": "human-readable-post",
  "version": "1.0.0",
  "description": "GitHub Action that generates human-readable release summaries from git diffs using LLMs",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc --noEmit && rollup -c rollup.config.ts --configPlugin @rollup/plugin-typescript",
    "test": "node --experimental-vm-modules node_modules/.bin/jest",
    "lint": "tsc --noEmit",
    "prepare": "husky"
  },
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^1.11.1",
    "@actions/exec": "^1.1.1",
    "@anthropic-ai/sdk": "^0.39.0",
    "@mistralai/mistralai": "^1.5.0",
    "openai": "^4.85.0"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^28.0.0",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.0",
    "@rollup/plugin-typescript": "^12.1.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.13.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "rollup": "^4.30.0",
    "ts-jest": "^29.2.0",
    "ts-node": "^10.9.2",
    "tslib": "^2.8.0",
    "typescript": "^5.7.0"
  }
}
